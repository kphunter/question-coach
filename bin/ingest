#!/usr/bin/env bash
# Wrapper script to run ingest.py inside Docker container
# This allows running ingestion commands without Python installed locally

set -e

command -v docker >/dev/null 2>&1 || {
    echo "Error: Docker is required but not installed."
    echo "Please install Docker from: https://docs.docker.com/get-docker/"
    exit 1
}

docker compose version >/dev/null 2>&1 || {
    echo "Error: Docker Compose is required but not available."
    echo "Please ensure Docker Compose is installed (comes with Docker Desktop)."
    exit 1
}

if [ -z "$GEMINI_API_KEY" ]; then
    echo "Error: GEMINI_API_KEY is not set."
    echo "Export it in your shell before running:"
    echo "  export GEMINI_API_KEY=your-key-here"
    exit 1
fi

if [ ! -f ingestion-config.yaml ] && [ -f ingestion-config.yaml.example ]; then
    cp ingestion-config.yaml.example ingestion-config.yaml
    echo "Created ingestion-config.yaml from example."
fi

# Ensure Qdrant and Ollama are running (ollama-pull starts automatically as a dependent)
docker compose -f docker-compose.kb.yml up -d qdrant ollama ollama-pull >/dev/null 2>&1

# Run the ingestion command — Docker Compose enforces depends_on conditions,
# so it will wait for qdrant (healthy) and ollama-pull (completed) before starting.
docker compose -f docker-compose.kb.yml run --rm ingestion "$@"
