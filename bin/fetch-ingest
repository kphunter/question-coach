#!/usr/bin/env sh
# Wrapper script to fetch web articles and ingest them using Docker
# This allows running fetch operations without Python installed locally

set -e

# Check if Docker is available
if ! command -v docker >/dev/null 2>&1; then
    echo "Error: Docker is required but not installed."
    echo "Please install Docker from: https://docs.docker.com/get-docker/"
    exit 1
fi

# Check if docker compose is available
if ! docker compose version >/dev/null 2>&1; then
    echo "Error: Docker Compose is required but not available."
    echo "Please ensure Docker Compose is installed (comes with Docker Desktop)."
    exit 1
fi

# Check if at least one URL argument is provided
if [ $# -eq 0 ]; then
    echo "Usage: fetch-ingest [options] <url> [url ...]"
    echo ""
    echo "Options:"
    echo "  --summary           Show AI-generated summary"
    echo "  --analysis          Show detailed AI analysis"
    echo "  --no-save          Don't save to inputs/fetched"
    echo ""
    echo "Examples:"
    echo "  fetch-ingest https://example.com/article"
    echo "  fetch-ingest --summary https://example.com/article"
    exit 1
fi

# Check if .env file exists
if [ ! -f .env ]; then
    echo "Warning: .env file not found. Creating from .env.example..."
    if [ -f .env.example ]; then
        cp .env.example .env
        echo "Created .env file. Please edit it and add your GEMINI_API_KEY."
        echo ""
    else
        echo "Error: .env.example not found. Cannot create .env file."
        exit 1
    fi
fi

# Check if ingestion-config.yaml exists
if [ ! -f ingestion-config.yaml ]; then
    echo "Info: ingestion-config.yaml not found. Creating from ingestion-config.yaml.example..."
    if [ -f ingestion-config.yaml.example ]; then
        cp ingestion-config.yaml.example ingestion-config.yaml
        echo "Created ingestion-config.yaml from example."
        echo ""
    fi
fi

# Ensure qdrant service is running
echo "Ensuring Qdrant service is running..."
docker compose up -d qdrant

# Wait for qdrant to be healthy
echo "Waiting for Qdrant to be ready..."
timeout=60
elapsed=0
while [ $elapsed -lt $timeout ]; do
    if docker compose ps qdrant | grep -q "healthy"; then
        echo "Qdrant is ready!"
        break
    fi
    sleep 2
    elapsed=$((elapsed + 2))
done

if [ $elapsed -ge $timeout ]; then
    echo "Warning: Qdrant may not be fully ready. Proceeding anyway..."
fi

echo ""
echo "Step 1: Fetching article(s)..."
echo "Running: fetch_article.py $*"
echo ""

# Run fetch_article.py with all arguments
docker compose run --rm --entrypoint "python" ingestion fetch_article.py "$@"

echo ""
echo "Step 2: Ingesting new documents..."
echo "Running: ingest.py process-new"
echo ""

# Run ingestion of new documents
docker compose run --rm ingestion process-new

echo ""
echo "Done! Article(s) fetched and ingested successfully."
