#!/usr/bin/env bash
# Fetch web articles and ingest them into the knowledge base.
# URLs can be passed as arguments or read from inputs/links.txt.

set -e

die() { echo "Error: $1" >&2; exit 1; }

# Validate that URL arguments look intact (not mangled by the shell).
# When a URL containing & is passed unquoted, the shell splits it into
# a backgrounded command and a second token.  Detect the common symptoms
# and tell the user to quote the URL.
for arg in "$@"; do
    if [[ "$arg" == http* ]]; then
        # A URL that was truncated at '&' will often end with a bare
        # query-parameter value (digits, etc.) right before the '&' the
        # shell consumed.  We can't detect that reliably, but we CAN
        # warn when the URL has a '?' but no '&' — which is suspicious
        # for multi-param URLs — or when a non-URL argument follows that
        # looks like a query-param fragment (e.g. "p=5180962").
        continue
    fi
    # A bare "key=value" token almost certainly came from a URL split on '&'.
    if [[ "$arg" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; then
        echo "Error: argument '$arg' looks like a query-string fragment." >&2
        echo "" >&2
        echo "  Your shell likely split the URL on the '&' character." >&2
        echo "  Wrap the URL in single quotes and try again:" >&2
        echo "" >&2
        echo "    ./bin/fetch-ingest 'https://example.com/page?a=1&b=2'" >&2
        exit 1
    fi
done

command -v docker >/dev/null 2>&1 || die "Docker is required. See: https://docs.docker.com/get-docker/"
docker compose version >/dev/null 2>&1 || die "Docker Compose is required."

if [ ! -f .env ]; then
    [ -f .env.example ] || die ".env not found and no .env.example to create it from."
    cp .env.example .env
    die ".env was missing; created from .env.example. Please add your GEMINI_API_KEY and re-run."
fi

if [ ! -f ingestion-config.yaml ] && [ -f ingestion-config.yaml.example ]; then
    cp ingestion-config.yaml.example ingestion-config.yaml
fi

# Ensure Qdrant is running and healthy
docker compose up -d qdrant >/dev/null 2>&1
timeout=60
elapsed=0
while [ $elapsed -lt $timeout ]; do
    docker compose ps qdrant 2>/dev/null | grep -q "healthy" && break
    sleep 2
    elapsed=$((elapsed + 2))
done

docker compose run --rm -e ORT_LOGGING_LEVEL=3 --entrypoint "python" ingestion fetch_article.py "$@"

echo ""
echo "Ingesting new documents..."
docker compose run --rm -e ORT_LOGGING_LEVEL=3 ingestion process-new
