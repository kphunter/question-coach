# RAG Knowledge Assistant - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# GEMINI API CONFIGURATION (Recommended)
# =============================================================================
# Get your API key from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
# Embedding Provider: "gemini", "ollama", or "sentence_transformers"
EMBEDDING_PROVIDER=gemini

# LLM Provider: "gemini" or "ollama"
LLM_PROVIDER=gemini

# =============================================================================
# QDRANT CONFIGURATION
# =============================================================================
# For local Qdrant (default)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# For Qdrant Cloud (uncomment and set these)
# QDRANT_URL=https://your-cluster.gcp.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-api-key

# Collection settings
COLLECTION_NAME=documents
DISTANCE_METRIC=cosine

# =============================================================================
# OLLAMA CONFIGURATION (Optional - if using local embeddings/LLM)
# =============================================================================
# Uncomment if using Ollama instead of Gemini
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_LLM_MODEL=llama3.2

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# NOTES
# =============================================================================
# 1. GEMINI SETUP (Recommended):
#    - Sign up at https://ai.google.dev/
#    - Get API key
#    - Set GEMINI_API_KEY above
#    - Set EMBEDDING_PROVIDER=gemini
#    - Set LLM_PROVIDER=gemini
#
# 2. OLLAMA SETUP (Local/Privacy-focused):
#    - Install: brew install ollama (macOS) or see https://ollama.ai
#    - Start: ollama serve
#    - Pull models: ollama pull nomic-embed-text && ollama pull llama3.2
#    - Set EMBEDDING_PROVIDER=ollama
#    - Set LLM_PROVIDER=ollama
#    - Uncomment OLLAMA_* variables above
#
# 3. HYBRID SETUP:
#    - Use Gemini for embeddings (faster, cloud-based)
#    - Use Ollama for LLM (privacy, local)
#    - Or vice versa!
#
# 4. QDRANT CLOUD:
#    - Sign up at https://cloud.qdrant.io/
#    - Create cluster and get credentials
#    - Uncomment and set QDRANT_URL and QDRANT_API_KEY
#    - Comment out QDRANT_HOST and QDRANT_PORT
